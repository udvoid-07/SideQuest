# ── Supabase ──────────────────────────────────────────────
# Create project at supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ── Google API key (Gemini AI only) ──────────────────────
# console.cloud.google.com → Create project → Credentials → API Key
# Enable: "Generative Language API" (Gemini — quest search, personalization, week plan)
# Location data uses OpenStreetMap/Overpass API — free, no key needed
# NEVER prefix with NEXT_PUBLIC_ — server-side only
GOOGLE_API_KEY=your_google_api_key

# ── Mobile (Expo) ─────────────────────────────────────────
# Same Supabase values with EXPO_PUBLIC_ prefix for React Native
# Copy to apps/mobile/.env
EXPO_PUBLIC_SUPABASE_URL=your_supabase_project_url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── Optional ──────────────────────────────────────────────
# EXPO_ACCESS_TOKEN=   # Only needed for EAS Build / OTA updates
